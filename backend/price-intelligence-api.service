[Unit]
Description=Price Intelligence AI API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/.openclaw/workspace/price-intelligence-ai/backend
Environment="PATH=/home/ubuntu/.openclaw/workspace/price-intelligence-ai/backend/venv/bin"
ExecStart=/home/ubuntu/.openclaw/workspace/price-intelligence-ai/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
