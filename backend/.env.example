# Bounty Recon AI Backend Environment

# Copy to .env: cp .env.example .env

# AWS Configuration for Amazon Nova Act SDK
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=amazon.nova-act-v1:0
BEDROCK_REGION=us-east-1

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Logging
LOG_LEVEL=INFO

# CORS (Comma-separated origins)
CORS_ORIGINS=*

# Storage (Future: DynamoDB + S3)
# DYNAMODB_TABLE_NAME=bounty-recon-scans
# S3_SCREENSHOT_BUCKET=bounty-recon-screenshots
